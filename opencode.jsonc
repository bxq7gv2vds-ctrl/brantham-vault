{
  "$schema": "https://opencode.ai/config.json",

  // Default = lowest-cost useful model. Specialized subagents override this.
  "model": "openrouter/deepseek/deepseek-v4-flash",
  "small_model": "openrouter/deepseek/deepseek-v4-flash",

  "instructions": [
    "AGENTS.md",
    "brantham/knowledge/skills/SKILLS_INDEX.md",
    "brantham/protocols/openrouter-opencode-runtime.md"
  ],

  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "ask",
    "bash": "ask",
    "websearch": "ask",
    "webfetch": "ask",
    "external_directory": "deny",
    "task": "allow"
  },

  "agent": {
    "brantham-router": {
      "mode": "primary",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "prompt": "{file:.opencode/agents/brantham-router.md}",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "bash": "ask",
        "websearch": "ask",
        "webfetch": "ask",
        "external_directory": "deny",
        "task": "allow"
      }
    },
    "brantham-hunter": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "prompt": "{file:.opencode/agents/brantham-hunter.md}"
    },
    "brantham-analyst": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-pro",
      "prompt": "{file:.opencode/agents/brantham-analyst.md}"
    },
    "brantham-writer": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "prompt": "{file:.opencode/agents/brantham-writer.md}"
    },
    "brantham-website": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-pro",
      "prompt": "{file:.opencode/agents/brantham-website.md}"
    },
    "brantham-qc": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-pro",
      "prompt": "{file:.opencode/agents/brantham-qc.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "websearch": "ask",
        "webfetch": "ask"
      }
    }
  }
}
